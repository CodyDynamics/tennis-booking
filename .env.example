# PostgreSQL (Docker / infra)
POSTGRES_USER==
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# API – DB connection (TypeORM)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=
DB_LOGGING=
# Set DB_SYNC=true on Render/production so TypeORM creates tables on first deploy (no migrations). Optional: set to false after first run.
# DB_SYNC=

# Redis (optional)
REDIS_PORT=

# API (monolith) – single port
PORT=

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=
# Short-lived access token (e.g. 15m). Match COOKIE_ACCESS_MAX_AGE_SECONDS in seconds.
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=
# Cookie max-age for access token (seconds), default 900 = 15m
# COOKIE_ACCESS_MAX_AGE_SECONDS=
#
# Cookies: plain HTTP (EC2 by IP, no TLS) must use COOKIE_SECURE=false or browsers drop Set-Cookie.
# With HTTPS (same host or cross-origin SPA), omit COOKIE_SECURE (defaults true in production) or set true.
# COOKIE_SECURE=false
# Optional override; if unset, production+Secure uses SameSite=None, else Lax (fine for same-site IP:80 + IP:3000).
# COOKIE_SAME_SITE=lax
#
# Behind nginx / load balancer: set so req.ip / secure flags match client (optional; see TRUST_PROXY in docs).
# TRUST_PROXY=true
#
# Extra CORS origins (comma-separated), e.g. http://44.199.235.11:3001
# CORS_ORIGINS=

# Redis: access-token blacklist on logout. Set REDIS_ENABLED=false if no Redis.
# REDIS_ENABLED=
# REDIS_HOST=
# REDIS_PORT=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Email: SMTP (Gmail), Resend, or Gmail API OAuth (docs/EMAIL_SETUP.md, docs/RESEND_SETUP.md)
# MAIL_PROVIDER=smtp | resend | cloud | none  (omit = auto: Resend if RESEND_API_KEY else SMTP if EMAIL_HOST)
# RESEND_API_KEY=re_...
# For MAIL_PROVIDER=cloud (Gmail API): same GOOGLE_CLIENT_ID/SECRET as OAuth login + refresh token for mail.
# If send fails with invalid_grant, regenerate GOOGLE_REFRESH_TOKEN in Google OAuth Playground.
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_SENDER_EMAIL=your-email@gmail.com
# GOOGLE_OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@booking-tennis.com

# Public URL of the Next.js app (no trailing slash). Used for CORS, OAuth redirects, and
# links in booking emails (e.g. /locations/.../courts?areaId=...). In production set to your real domain.
FRONTEND_URL=http://localhost:3000

# Auth: login OTP (default off = email + password only). Set true to require email OTP after password.
# LOGIN_OTP_ENABLED=true

# Auth: registration email OTP (default on). Set false/0/off/no (any case) to skip email entirely:
# user is created on first submit (no OTP screen); GET /auth/config returns registrationEmailEnabled: false.
# SEND_REGISTRATION_EMAIL=false

# Environment
NODE_ENV=development
